# Production Environment Configuration
environment                = "prod"
cloud_run_min_instances    = 1
cloud_run_max_instances    = 10
cloud_sql_tier             = "db-n1-standard-4"
cloud_sql_storage_gb       = 100
enable_ha                  = true
enable_vpc                 = true
log_retention_days         = 90
log_level                  = "WARNING"
pubsub_message_retention_days = 7
