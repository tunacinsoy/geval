# Terraform State Files
*.tfstate
*.tfstate.*
.terraform.lock.hcl
terraform.lock.hcl

# Terraform Cache
.terraform/
.terraform.d/

# Local variable override files
*.tfvars
*.tfvars.json
!terraform.tfvars        # Shared variables (no secrets)
!terraform.tfvars.dev    # Environment configs
!terraform.tfvars.staging
!terraform.tfvars.prod

# Terraform Plan Files
*.tfplan
tfplan.dev
tfplan.staging
tfplan.prod

# Terraform Cloud Credentials
.terraformrc
terraform.rc

# IDE Files
.idea/
.vscode/
*.swp
*.swo
*.swn
.DS_Store

# Crash Log
crash.log
crash.*.log

# Exclude All .tfvars files, if it contains sensitive data use a separate file
# !example.tfvars

# Ignore override files, as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Ignore CLI configuration files
.terraformignore

# Ignore plan files
*.tfplan

# Ignore lock files
**/.terraform.lock.hcl

# Ignore Mac .DS_Store files
.DS_Store

# Ignore editor backups
*~
*.backup
*.swp

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
*.logs

# Temporary files
*.tmp
*.temp

# OS-specific
Thumbs.db
desktop.ini

# Python artifacts
__pycache__/
*.py[cod]
*$py.class

# Node.js artifacts (if using Node.js with Terraform modules)
node_modules/
package-lock.json
yarn.lock

# Outputs
output.tf.json

# Service account keys (NEVER COMMIT!)
*-key.json
*-service-account.json
service-account*.json
gcp-key.json

# kubeconfig files
kubeconfig
kubeconfig.*
