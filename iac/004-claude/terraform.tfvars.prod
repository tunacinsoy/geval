# Production environment configuration

environment             = "prod"
instance_type           = "db.t3.small"
storage_size            = 30
multi_az                = true
backup_retention_days   = 90
enable_deletion_protection = true
enable_monitoring       = true
monitoring_interval     = 60
rds_proxy_enabled       = true

# Database configuration
database_name           = "orders_db"
db_username             = "postgres"
password_length         = 32

# Network configuration
vpc_cidr                = "10.0.0.0/16"
database_subnet_1_cidr  = "10.0.10.0/24"
database_subnet_2_cidr  = "10.0.11.0/24"

# Backup and maintenance windows (production use case: earlier backup window for compliance)
backup_window           = "02:00-03:00"
maintenance_window      = "sun:03:00-sun:04:00"

# Tags
tags = {
  Environment = "production"
  CostCenter  = "customer-orders"
  Owner       = "platform-team"
  Compliance  = "pci-dss"
}
