resource "aws_security_group" "db_sg" {
  name        = "customer-database-db-sg"
  description = "Allow inbound traffic to the database"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.app_sg.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "app_sg" {
  name        = "customer-database-app-sg"
  description = "Allow inbound traffic to the application"
  vpc_id      = aws_vpc.main.id

  # In a real-world scenario, you would restrict this to the application's IP or a load balancer
  ingress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}
